// Signal — personal stock watchlist + AI recommendation app
// Single-user, Postgres via Neon.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled connection, used at runtime
  directUrl = env("DIRECT_URL") // direct (unpooled) connection, used for migrations
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  ticker    String   @unique
  notes     String?
  addedAt   DateTime @default(now()) @map("added_at")

  @@map("watchlist")
}

model Recommendation {
  id             Int      @id @default(autoincrement())
  ticker         String
  recommendation String // buy | hold | sell
  confidence     String // low | medium | high
  reasoning      String
  keyRisks       String   @map("key_risks")
  priceAtRec     Float?   @map("price_at_rec")
  createdAt      DateTime @default(now()) @map("created_at")

  // Risk tolerance (0-100) the call was generated under. Nullable — rows
  // created before this field existed won't have it.
  riskTolerance Int? @map("risk_tolerance")

  // Backtest evaluation, filled in later by the daily evaluation cron.
  // priceAfter7d is an interim checkpoint (informational only); outcomeCorrect
  // is decided at the 30-day mark — see lib/backtest.ts for the rationale.
  priceAfter7d   Float?    @map("price_after_7d")
  priceAfter30d  Float?    @map("price_after_30d")
  outcomeCorrect Boolean?  @map("outcome_correct")
  evaluatedAt    DateTime? @map("evaluated_at")

  @@index([ticker, createdAt])
  @@index([createdAt])
  @@map("recommendations")
}

// Prevents duplicate SMS for the same event.
model NotificationLog {
  id        Int      @id @default(autoincrement())
  eventKey  String   @unique @map("event_key") // stable hash of the triggering event
  eventType String   @map("event_type") // insider_buy | rec_flip
  ticker    String
  message   String
  sentAt    DateTime @default(now()) @map("sent_at")

  @@index([ticker])
  @@map("notification_log")
}
